{
  "entities": {
    "CompetitorImage": {
      "title": "Competitor Image",
      "description": "An image uploaded to the competitor library",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "data": { "type": "string", "description": "Base64 image data or URL" },
        "parsedData": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "categoryId", "data", "createdAt", "updatedAt"]
    },
    "StructureLibraryImage": {
      "title": "Structure Library Image",
      "description": "An image uploaded to the modular structure library",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "data": { "type": "string", "description": "Base64 image data or URL" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "category", "data", "name", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}/competitorImages/{imageId}": {
      "schema": { "$ref": "#/entities/CompetitorImage" },
      "description": "User's competitor images"
    },
    "/users/{userId}/structureImages/{imageId}": {
      "schema": { "$ref": "#/entities/StructureLibraryImage" },
      "description": "User's structure library images"
    }
  }
}
